<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zadanie Lekcyjne</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #f0f2f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 90%; max-width: 500px; text-align: center; }
        h1 { color: #1a73e8; margin-bottom: 5px; }
        .task-container { background: #fff9c4; border: 1px solid #fbc02d; padding: 20px; border-radius: 8px; margin: 25px 0; text-align: left; font-size: 1.1em; line-height: 1.6; }
        button { background: #28a745; color: white; border: none; padding: 15px 30px; font-size: 18px; font-weight: bold; border-radius: 6px; cursor: pointer; width: 100%; transition: background 0.3s; }
        button:hover { background: #218838; }
        button:disabled { background: #6c757d; cursor: not-allowed; }
        .footer { margin-top: 20px; font-size: 0.8em; color: #888; }
    </style>
</head>
<body data-task-id="{{ task_id }}">
    <div class="card">
        <h1>Witaj, {{ name }}</h1>
        <div class="task-container">
            <strong>Polecenie:</strong><br>
            {{ task }}
        </div>
        <button id="mainBtn" onclick="sendDone()">ZADANIE WYKONANE</button>
        <div class="footer">Strona odświeży się automatycznie po zmianie zadania.</div>
    </div>

    <script>
        const myTaskId = document.body.getAttribute('data-task-id');

        function checkUpdate() {
            fetch('/check_updates')
                .then(res => res.json())
                .then(data => {
                    if (data.task_id !== myTaskId) {
                        location.reload();
                    }
                });
        }

        function sendDone() {
            if(confirm("Czy na pewno chcesz zgłosić wykonanie zadania?")) {
                fetch('/done', { method: 'POST' }).then(res => {
                    if(res.ok) {
                        const btn = document.getElementById('mainBtn');
                        btn.disabled = true;
                        btn.innerText = "ZGŁOSZONO GOTOWOŚĆ";
                        btn.style.background = "#6c757d";
                    }
                });
            }
        }

        setInterval(checkUpdate, 3000);
    </script>
</body>
</html>