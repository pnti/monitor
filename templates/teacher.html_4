<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>Panel Nauczyciela - Monitor</title>
    <!-- Linkowanie do dedykowanego pliku CSS dla nauczyciela -->
    <link rel="stylesheet" href="{{ url_for('static', filename='teacher_style.css') }}">
</head>
<body>
    <div class="control-panel">
        <h2>Panel Sterowania Lekcją</h2>
        <div class="task-info">
            <strong>Zadanie {{ task_num }} / {{ total_tasks }}:</strong><br>
            <span id="currentTaskDisplay">{{ current_task }}</span>
        </div>
        <button class="btn-next" onclick="nextTask()" {% if task_num == total_tasks %}disabled{% endif %}>
            NASTĘPNE ZADANIE
        </button>
    </div>

    <div class="grid" id="statusGrid">
        {% for ip, name in students.items() %}
        <div id="box-{{ ip | replace('.', '-') }}" class="student-box pending">
            <strong>{{ name }}</strong><br>
            <small>{{ ip }}</small><br>
            <span class="status-text">Oczekiwanie...</span>
        </div>
        {% endfor %}
    </div>

    <script>
        function nextTask() {
            if(confirm("Czy na pewno chcesz przejść do następnego zadania? Statusy zostaną zresetowane.")) {
                fetch('/next_task', { method: 'POST' })
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                });
            }
        }

        function refreshStatus() {
            fetch('/status').then(res => res.json()).then(data => {
                for (let ip in data.progress) {
                    const id = 'box-' + ip.replace(/\./g, '-');
                    const el = document.getElementById(id);
                    if (!el) continue;
                    
                    const statusTxt = el.querySelector('.status-text');
                    
                    if (data.help[ip]) {
                        el.className = 'student-box need-help';
                        statusTxt.innerText = "POTRZEBNA POMOC!";
                    } else if (data.progress[ip]) {
                        el.className = 'student-box done';
                        statusTxt.innerText = "ZAKOŃCZYŁ";
                    } else {
                        el.className = 'student-box pending';
                        statusTxt.innerText = "W trakcie...";
                    }
                }
            });
        }

        // Odświeżaj widok monitora co 2 sekundy
        setInterval(refreshStatus, 2000);
    </script>
</body>
</html>